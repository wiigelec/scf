#!/usr/bin/env python3
# Run governed development session restoration from the repository root.

from __future__ import annotations

import sys
from pathlib import Path

ROOT = Path.cwd()
PACKAGE_ROOT = ROOT / "src"
REQUIRED_SENTINELS = (
    ROOT / ".git",
    ROOT / "authority/core/SCF-CORE.json",
    ROOT / "docs/OFFICIAL-GOVERNED-DEVELOPMENT-PROCESS.md",
    ROOT / "docs/GOVERNED-DEVELOPMENT-SESSION-RESTORATION.md",
)

missing = [item.relative_to(ROOT).as_posix() for item in REQUIRED_SENTINELS if not item.exists()]
if missing:
    print(
        "Restoration invocation failed: current directory is not the SCF "
        "repository root; missing: " + ", ".join(missing)
    )
    raise SystemExit(2)

sys.path.insert(0, str(PACKAGE_ROOT))

from scf_restoration.cli import main  # noqa: E402

raise SystemExit(main(ROOT))
