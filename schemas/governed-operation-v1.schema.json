{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/wiigelec/scf/schemas/governed-operation-v1.schema.json",
  "title": "SCF governed operation version 1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "operation_id",
    "operation_type",
    "executor_version",
    "operation_digest",
    "repository",
    "guards",
    "authorization",
    "inputs",
    "expected_mutations",
    "validation",
    "publication",
    "result"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "operation_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{7,127}$"
    },
    "operation_type": {
      "enum": [
        "repository-interrogation",
        "local-file-operations",
        "git-publication",
        "governed-validation"
      ]
    },
    "executor_version": {
      "const": "0.1.0"
    },
    "operation_digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "root",
        "origin"
      ],
      "properties": {
        "root": {
          "type": "string",
          "minLength": 1
        },
        "origin": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "guards": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "branch",
        "head",
        "clean"
      ],
      "properties": {
        "branch": {
          "type": "string",
          "minLength": 1
        },
        "head": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "clean": {
          "type": "boolean"
        }
      }
    },
    "authorization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "interrogate",
        "edit",
        "validate",
        "stage",
        "commit",
        "push",
        "issue",
        "pull_request",
        "review",
        "merge",
        "close_issue"
      ],
      "properties": {
        "interrogate": {
          "const": true
        },
        "edit": {
          "const": false
        },
        "validate": {
          "const": false
        },
        "stage": {
          "const": false
        },
        "commit": {
          "const": false
        },
        "push": {
          "const": false
        },
        "issue": {
          "const": false
        },
        "pull_request": {
          "const": false
        },
        "review": {
          "const": false
        },
        "merge": {
          "const": false
        },
        "close_issue": {
          "const": false
        }
      }
    },
    "inputs": {
      "type": "object"
    },
    "expected_mutations": {
      "type": "object"
    },
    "validation": {
      "type": "object",
      "maxProperties": 0
    },
    "publication": {
      "type": "object",
      "maxProperties": 0
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "directory",
        "filename"
      ],
      "properties": {
        "directory": {
          "type": "string",
          "minLength": 1
        },
        "filename": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{7,191}\\.result\\.json$"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "operation_type": {
            "const": "repository-interrogation"
          }
        }
      },
      "then": {
        "properties": {
          "inputs": {
            "maxProperties": 0
          },
          "expected_mutations": {
            "maxProperties": 0
          },
          "authorization": {
            "properties": {
              "interrogate": {
                "const": true
              },
              "edit": {
                "const": false
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "operation_type": {
            "const": "local-file-operations"
          }
        }
      },
      "then": {
        "properties": {
          "authorization": {
            "properties": {
              "interrogate": {
                "const": true
              },
              "edit": {
                "const": true
              }
            }
          },
          "inputs": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "operations"
            ],
            "properties": {
              "operations": {
                "type": "array",
                "minItems": 1,
                "maxItems": 100,
                "items": {
                  "type": "object",
                  "required": [
                    "action",
                    "path",
                    "content",
                    "content_sha256",
                    "mode"
                  ],
                  "properties": {
                    "action": {
                      "enum": [
                        "create",
                        "replace"
                      ]
                    },
                    "path": {
                      "type": "string",
                      "minLength": 1
                    },
                    "content": {
                      "type": "string"
                    },
                    "content_sha256": {
                      "type": "string",
                      "pattern": "^[0-9a-f]{64}$"
                    },
                    "expected_sha256": {
                      "type": "string",
                      "pattern": "^[0-9a-f]{64}$"
                    },
                    "mode": {
                      "type": "string",
                      "pattern": "^0[0-7]{3}$"
                    }
                  }
                }
              }
            }
          },
          "expected_mutations": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "files"
            ],
            "properties": {
              "files": {
                "type": "array"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "operation_type": {
            "const": "git-publication"
          }
        }
      },
      "then": {
        "properties": {
          "authorization": {
            "properties": {
              "interrogate": {
                "const": true
              },
              "stage": {
                "const": true
              },
              "commit": {
                "const": true
              }
            }
          },
          "inputs": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "paths",
              "message"
            ],
            "properties": {
              "paths": {
                "type": "array",
                "minItems": 1,
                "maxItems": 500,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "message": {
                "type": "string",
                "minLength": 1,
                "maxLength": 4096
              }
            }
          },
          "expected_mutations": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "paths",
              "parent_head"
            ],
            "properties": {
              "paths": {
                "type": "array",
                "minItems": 1
              },
              "parent_head": {
                "type": "string",
                "pattern": "^[0-9a-f]{40}$"
              }
            }
          },
          "publication": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "push",
              "remote",
              "branch"
            ],
            "properties": {
              "push": {
                "type": "boolean"
              },
              "remote": {
                "type": "string",
                "minLength": 1
              },
              "branch": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "operation_type": {
            "const": "governed-validation"
          }
        }
      },
      "then": {
        "properties": {
          "authorization": {
            "properties": {
              "interrogate": {
                "const": true
              },
              "validate": {
                "const": true
              },
              "edit": {
                "const": false
              },
              "stage": {
                "const": false
              },
              "commit": {
                "const": false
              },
              "push": {
                "const": false
              }
            }
          },
          "inputs": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "profiles"
            ],
            "properties": {
              "profiles": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "enum": [
                    "governed-executor-tests",
                    "permanent-validation-tests",
                    "repository-complete",
                    "whitespace"
                  ]
                }
              }
            }
          },
          "expected_mutations": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "profiles"
            ],
            "properties": {
              "profiles": {
                "type": "array",
                "minItems": 1
              }
            }
          },
          "validation": {
            "type": "object",
            "maxProperties": 0
          },
          "publication": {
            "type": "object",
            "maxProperties": 0
          }
        }
      }
    }
  ]
}
